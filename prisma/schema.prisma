// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  name String
  email String @unique
  password String
  role Role
  deliveriesAsClient Delivery[] @relation("ClientDeliveries")
  deliveriesAsDriver Delivery[] @relation("DriverDeliveries")
  createdAt DateTime @default(now())
}

model Delivery {
  id String @id @default(cuid())
  description String

  client User @relation("ClientDeliveries", fields: [clientId], references: [id])
  clientId String 

  driver User @relation("DriverDeliveries", fields: [driverId], references: [id])
  driverId String

  origin Address @relation("OriginAddress", fields: [originId], references: [id])
  originId String

  destination Address @relation("DestinationAddress", fields: [destinationId], references: [id])
  destinationId String

  status DeliveryStatus @default(PENDING)
  updates DeliveryUpdates[]
  createdAt DateTime @default(now())
}

model DeliveryUpdates {
  id String @id @default(cuid())
  delivery Delivery @relation(fields: [deliveryId], references: [id])
  deliveryId String
  status DeliveryStatus
  location String
  note String?
  updatedAt DateTime @default(now())
}

model Address {
  id String @id @default(cuid())
  street String
  city String
  state String
  country String
  zipCode String

  originDeliveries      Delivery[] @relation("OriginAddress")
  destinationDeliveries Delivery[] @relation("DestinationAddress")
}

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}